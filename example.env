# ============================================================
# Ham Sandwich — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file — it should be in .gitignore.
#
# See LLM/LLM-OVERVIEW.md for project overview.
# See LLM/LLM-FIREBASE.md for Firebase setup instructions.
# See LLM/LLM-CLOUDFLARE.md for Cloudflare setup instructions.
# See LLM/LLM-DOCKER.md for local Docker development.
# ============================================================

# ------------------------------------------------------------
# Firebase — Client-side config
# ------------------------------------------------------------
# Get these from Firebase Console → Project Settings → General → Your apps → Web app
# These are public keys safe for client-side use. Security is enforced by Firebase Security Rules.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=ham-sandwich.firebaseapp.com
FIREBASE_PROJECT_ID=ham-sandwich
FIREBASE_STORAGE_BUCKET=ham-sandwich.appspot.com
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ------------------------------------------------------------
# Cloudflare Workers — Server-side secrets
# ------------------------------------------------------------
# These are set in Cloudflare Dashboard (Workers & Pages → Settings → Environment variables)
# or via `wrangler pages secret put <KEY>`.
# For local dev, they are read from this .env file by Wrangler.

# Salt for any server-side encryption operations (generate a random string)
ENCRYPTION_SALT=

# ------------------------------------------------------------
# Firebase Emulators — Local development only
# ------------------------------------------------------------
# These tell the app container where to find the Firebase emulator services.
# Only used when running locally via Docker (see LLM-DOCKER.md).
# When running without Docker, the app auto-detects localhost.
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# ------------------------------------------------------------
# Local Development — Geolocation defaults
# ------------------------------------------------------------
# Cloudflare provides geolocation via request.cf in production.
# For local dev, these values are used as fallbacks (see LLM-DOCKER.md).
CF_COUNTRY=GB
CF_CITY=London
CF_REGION=England

# ------------------------------------------------------------
# Node environment
# ------------------------------------------------------------
NODE_ENV=development
